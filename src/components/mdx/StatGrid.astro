---
interface Item {
  label: string;
  value: string;
  note?: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<div class="mdx-stat-grid">
  {items.map((item) => (
    <div class="mdx-stat-card">
      <div class="mdx-stat-card__label">{item.label}</div>
      <div class="mdx-stat-card__value">{item.value}</div>
      {item.note && <div class="mdx-stat-card__note">{item.note}</div>}
    </div>
  ))}
</div>
