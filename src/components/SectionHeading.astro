---
interface Props {
  eyebrow: string;
  title: string;
  copy?: string;
}

const { eyebrow, title, copy } = Astro.props;
---

<div class="section-heading">
  <div>
    <div class="eyebrow">{eyebrow}</div>
    <h2 class="section-title">{title}</h2>
    {copy && <p class="section-copy">{copy}</p>}
  </div>
  <slot />
</div>
