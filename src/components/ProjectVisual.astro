---
type VisualKind = "dashboard" | "content" | "lab" | "blog" | "molecules" | "tooling" | "reaction" | "porous" | "lattice" | "network" | "coding" | "default";

interface Props {
  id: string;
  label: string;
  title?: string;
  pattern?: string;
}

const { id, label, title, pattern = "grid" } = Astro.props;
const safeId = id.replace(/[^a-zA-Z0-9_-]/g, "-");
const visualById: Record<string, VisualKind> = {
  "personal-dashboard": "dashboard",
  "content-system": "content",
  "self-hosting-lab": "lab",
  "personal-blog-workspace": "blog",
  "co2-eor-md": "molecules",
  "ai-tools-log": "tooling",
  "lammps-reactor": "reaction",
  "porems-mod": "porous",
  "lbmpy-study": "lattice",
  "network-tuning": "network",
  "vibe-coding": "coding"
};
const coverCopyById: Record<string, { label: string; mark: string }> = {
  "personal-dashboard": {
    label: "DASH",
    mark: "PRIVATE OPERATIONS PANEL"
  },
  "content-system": {
    label: "CMS",
    mark: "STRUCTURED CONTENT FLOW"
  },
  "self-hosting-lab": {
    label: "OPS",
    mark: "LOCAL SERVICES · MONITORING"
  },
  "personal-blog-workspace": {
    label: "BLOG",
    mark: "PERSONAL KNOWLEDGE SPACE"
  }
};
const visual = visualById[id] ?? "default";
const coverCopy = coverCopyById[id];
const shortLabel = coverCopy?.label ?? (label.length > 4 ? label.slice(0, 4) : label);
const mark = coverCopy?.mark ?? title ?? label;
---

<svg
  class={`project-visual project-visual--${visual} project-visual--pattern-${pattern}`}
  viewBox="0 0 640 420"
  role="img"
  aria-label={`${label} visual`}
  preserveAspectRatio="xMidYMid slice"
>
  <defs>
    <linearGradient id={`pv-bg-${safeId}`} x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="var(--pv-bg-a)" />
      <stop offset="0.56" stop-color="var(--pv-bg-b)" />
      <stop offset="1" stop-color="var(--pv-bg-c)" />
    </linearGradient>
    <radialGradient id={`pv-glow-${safeId}`} cx="72%" cy="20%" r="58%">
      <stop offset="0" stop-color="var(--pv-glow-a)" stop-opacity="0.9" />
      <stop offset="0.58" stop-color="var(--pv-glow-b)" stop-opacity="0.28" />
      <stop offset="1" stop-color="var(--pv-glow-b)" stop-opacity="0" />
    </radialGradient>
    <pattern id={`pv-grid-${safeId}`} width="38" height="38" patternUnits="userSpaceOnUse">
      <path d="M 38 0 L 0 0 0 38" fill="none" stroke="var(--pv-pattern)" stroke-width="1" />
    </pattern>
    <pattern id={`pv-dots-${safeId}`} width="28" height="28" patternUnits="userSpaceOnUse">
      <circle cx="4" cy="4" r="1.8" fill="var(--pv-pattern)" />
    </pattern>
    <clipPath id={`pv-clip-${safeId}`}>
      <rect x="0" y="0" width="640" height="420" rx="34" />
    </clipPath>
  </defs>

  <g clip-path={`url(#pv-clip-${safeId})`}>
    <rect width="640" height="420" fill={`url(#pv-bg-${safeId})`} />
    <rect width="640" height="420" fill={`url(#pv-glow-${safeId})`} />
    <rect class="project-visual__pattern project-visual__pattern-grid" width="640" height="420" fill={`url(#pv-grid-${safeId})`} />
    <rect class="project-visual__pattern project-visual__pattern-dots" width="640" height="420" fill={`url(#pv-dots-${safeId})`} />
    <path class="project-visual__sweep" d="M-40 330 C120 238 252 282 392 178 C482 110 540 58 704 70 L704 462 L-40 462 Z" />
    <circle class="project-visual__orb project-visual__orb-a" cx="535" cy="82" r="76" />
    <circle class="project-visual__orb project-visual__orb-b" cx="92" cy="340" r="108" />

    {visual === "molecules" && (
      <g class="project-visual__motif project-visual__motif-molecules">
        <path class="project-visual__bond project-visual__bond-a" d="M174 248 L274 174 L390 222 L482 138" />
        <path class="project-visual__bond project-visual__bond-b" d="M274 174 L300 292 L390 222" />
        <circle class="project-visual__node project-visual__node-a" cx="174" cy="248" r="42" />
        <circle class="project-visual__node project-visual__node-b" cx="274" cy="174" r="34" />
        <circle class="project-visual__node project-visual__node-c" cx="300" cy="292" r="48" />
        <circle class="project-visual__node project-visual__node-d" cx="390" cy="222" r="38" />
        <circle class="project-visual__node project-visual__node-e" cx="482" cy="138" r="28" />
      </g>
    )}

    {visual === "tooling" && (
      <g class="project-visual__motif project-visual__motif-tooling">
        <rect class="project-visual__panel" x="148" y="110" width="348" height="206" rx="34" />
        <path class="project-visual__code-lines" d="M206 178 H438 M206 230 H378 M206 282 H432" />
        <circle class="project-visual__chip project-visual__chip-a" cx="210" cy="142" r="10" />
        <circle class="project-visual__chip project-visual__chip-b" cx="246" cy="142" r="10" />
        <circle class="project-visual__chip project-visual__chip-c" cx="282" cy="142" r="10" />
        <path class="project-visual__spark" d="M478 88 L516 126 L478 164 L440 126 Z" />
      </g>
    )}

    {visual === "reaction" && (
      <g class="project-visual__motif project-visual__motif-reaction">
        <path class="project-visual__reaction-line" d="M132 214 H448" />
        <path class="project-visual__reaction-arrow" d="M410 174 L486 214 L410 254" />
        <circle class="project-visual__reactant project-visual__reactant-a" cx="168" cy="178" r="36" />
        <circle class="project-visual__reactant project-visual__reactant-b" cx="232" cy="252" r="30" />
        <circle class="project-visual__product project-visual__product-a" cx="510" cy="162" r="34" />
        <circle class="project-visual__product project-visual__product-b" cx="518" cy="266" r="42" />
        <path class="project-visual__reaction-bonds" d="M166 178 L232 252 M510 162 L518 266" />
      </g>
    )}

    {visual === "dashboard" && (
      <g class="project-visual__motif project-visual__motif-dashboard">
        <rect class="project-visual__dashboard-frame" x="116" y="92" width="408" height="250" rx="34" />
        <rect class="project-visual__dashboard-stat project-visual__dashboard-stat-a" x="158" y="132" width="76" height="62" rx="14" />
        <rect class="project-visual__dashboard-stat project-visual__dashboard-stat-b" x="260" y="132" width="76" height="62" rx="14" />
        <rect class="project-visual__dashboard-stat project-visual__dashboard-stat-c" x="362" y="132" width="76" height="62" rx="14" />
        <path class="project-visual__dashboard-chart" d="M160 286 C212 252 244 302 294 240 S382 290 470 218" />
        <circle class="project-visual__dashboard-dot project-visual__dashboard-dot-a" cx="160" cy="286" r="11" />
        <circle class="project-visual__dashboard-dot project-visual__dashboard-dot-b" cx="294" cy="240" r="11" />
        <circle class="project-visual__dashboard-dot project-visual__dashboard-dot-c" cx="470" cy="218" r="11" />
      </g>
    )}

    {visual === "content" && (
      <g class="project-visual__motif project-visual__motif-content">
        <path class="project-visual__content-folder" d="M128 152 H286 L316 184 V306 H128 Z" />
        <path class="project-visual__content-tab" d="M128 152 H208 L232 184 H128 Z" />
        <rect class="project-visual__content-file project-visual__content-file-a" x="346" y="122" width="136" height="82" rx="14" />
        <rect class="project-visual__content-file project-visual__content-file-b" x="346" y="224" width="136" height="82" rx="14" />
        <path class="project-visual__content-flow" d="M196 230 H314 C334 230 334 164 346 164 M314 230 C334 230 334 264 346 264" />
        <path class="project-visual__content-lines" d="M170 218 H264 M170 250 H246 M370 152 H446 M370 254 H446 M370 280 H426" />
      </g>
    )}

    {visual === "lab" && (
      <g class="project-visual__motif project-visual__motif-lab">
        <rect class="project-visual__lab-rack project-visual__lab-rack-a" x="154" y="116" width="120" height="192" rx="24" />
        <rect class="project-visual__lab-rack project-visual__lab-rack-b" x="366" y="116" width="120" height="192" rx="24" />
        <path class="project-visual__lab-heartbeat" d="M294 224 H326 L344 178 L366 270 L388 224 H510" />
        <circle class="project-visual__lab-light project-visual__lab-light-a" cx="186" cy="158" r="9" />
        <circle class="project-visual__lab-light project-visual__lab-light-b" cx="186" cy="208" r="9" />
        <circle class="project-visual__lab-light project-visual__lab-light-c" cx="186" cy="258" r="9" />
        <circle class="project-visual__lab-light project-visual__lab-light-d" cx="398" cy="158" r="9" />
        <circle class="project-visual__lab-light project-visual__lab-light-e" cx="398" cy="208" r="9" />
        <circle class="project-visual__lab-light project-visual__lab-light-f" cx="398" cy="258" r="9" />
      </g>
    )}

    {visual === "blog" && (
      <g class="project-visual__motif project-visual__motif-blog">
        <rect class="project-visual__blog-window" x="112" y="104" width="416" height="224" rx="34" />
        <circle class="project-visual__blog-chip project-visual__blog-chip-a" cx="156" cy="142" r="9" />
        <circle class="project-visual__blog-chip project-visual__blog-chip-b" cx="184" cy="142" r="9" />
        <circle class="project-visual__blog-chip project-visual__blog-chip-c" cx="212" cy="142" r="9" />
        <path class="project-visual__blog-heading" d="M158 194 H406 M158 230 H354 M158 266 H446" />
        <path class="project-visual__blog-bookmark" d="M460 176 V254 L430 232 L400 254 V176 Z" />
      </g>
    )}

    {visual === "porous" && (
      <g class="project-visual__motif project-visual__motif-porous">
        <path class="project-visual__pore-shell" d="M120 270 C170 120 330 90 420 150 C510 208 504 332 392 352 C278 372 92 360 120 270 Z" />
        <circle class="project-visual__pore project-visual__pore-a" cx="242" cy="198" r="42" />
        <circle class="project-visual__pore project-visual__pore-b" cx="360" cy="242" r="58" />
        <circle class="project-visual__pore project-visual__pore-c" cx="246" cy="310" r="34" />
        <path class="project-visual__channel" d="M154 282 C228 246 300 282 372 220 C414 184 452 180 506 198" />
      </g>
    )}

    {visual === "lattice" && (
      <g class="project-visual__motif project-visual__motif-lattice">
        <path class="project-visual__lattice-grid" d="M150 126 H494 M150 198 H494 M150 270 H494 M150 342 H494 M166 110 V342 M238 110 V342 M310 110 V342 M382 110 V342 M454 110 V342" />
        <path class="project-visual__lattice-flow" d="M166 342 C214 250 296 306 334 218 C366 144 428 150 494 126" />
        <circle class="project-visual__lattice-node project-visual__lattice-node-a" cx="166" cy="342" r="14" />
        <circle class="project-visual__lattice-node project-visual__lattice-node-b" cx="310" cy="270" r="14" />
        <circle class="project-visual__lattice-node project-visual__lattice-node-c" cx="382" cy="198" r="14" />
        <circle class="project-visual__lattice-node project-visual__lattice-node-d" cx="494" cy="126" r="14" />
      </g>
    )}

    {visual === "network" && (
      <g class="project-visual__motif project-visual__motif-network">
        <path class="project-visual__network-link project-visual__network-link-a" d="M154 252 C222 132 350 322 488 164" />
        <path class="project-visual__network-link project-visual__network-link-b" d="M180 146 C258 258 374 92 512 270" />
        <circle class="project-visual__network-node project-visual__network-node-a" cx="154" cy="252" r="32" />
        <circle class="project-visual__network-node project-visual__network-node-b" cx="252" cy="180" r="24" />
        <circle class="project-visual__network-node project-visual__network-node-c" cx="336" cy="264" r="28" />
        <circle class="project-visual__network-node project-visual__network-node-d" cx="488" cy="164" r="34" />
        <circle class="project-visual__network-node project-visual__network-node-e" cx="512" cy="270" r="26" />
      </g>
    )}

    {visual === "coding" && (
      <g class="project-visual__motif project-visual__motif-coding">
        <path class="project-visual__bracket project-visual__bracket-left" d="M220 160 L150 214 L220 268" />
        <path class="project-visual__bracket project-visual__bracket-right" d="M420 160 L490 214 L420 268" />
        <path class="project-visual__slash" d="M356 126 L286 302" />
        <rect class="project-visual__code-window" x="116" y="96" width="408" height="248" rx="34" />
      </g>
    )}

    {visual === "default" && (
      <g class="project-visual__motif project-visual__motif-default">
        <rect x="154" y="112" width="332" height="212" rx="42" />
        <path d="M204 256 C270 154 354 310 436 178" />
        <circle cx="204" cy="256" r="22" />
        <circle cx="436" cy="178" r="22" />
      </g>
    )}

    <text class="project-visual__label" x="46" y="74">{shortLabel}</text>
    <text class="project-visual__mark" x="46" y="360">{mark}</text>
  </g>
</svg>
