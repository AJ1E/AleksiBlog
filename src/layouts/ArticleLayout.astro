---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import { formatDisplayDate, tagHref } from "../lib/content";
import { siteMeta } from "../data/site";

interface Props {
  post: CollectionEntry<"blog">;
  headings: { slug: string; text: string; depth: number }[];
  relatedPosts: CollectionEntry<"blog">[];
}

const { post, headings, relatedPosts } = Astro.props;
const authorAvatar = post.data.author.avatar;
const authorHasImageAvatar = authorAvatar.startsWith("/");
const authorLinks = [
  { label: "GitHub", href: siteMeta.github, external: true },
  { label: "Email", href: `mailto:${siteMeta.email}`, external: false }
];
---

<BaseLayout
  title={`${post.data.title} — ${siteMeta.title}`}
  description={post.data.excerpt}
  currentPath="/blog"
  hideHeader={true}
  hideFooter={true}
>
  <nav class="article-nav">
    <div class="article-nav__inner">
      <div class="article-nav__left">
        <a href="/blog/" class="article-nav__back">← 返回</a>
        <span class="article-nav__sep">|</span>
        <div class="article-nav__brand">
          <img class="article-nav__mark" src="/favicon.svg" alt="" width="24" height="24" decoding="async" />
          <span>{siteMeta.title}</span>
        </div>
      </div>
      <div class="article-nav__right">
        <span class="article-nav__read">{post.data.readTime} 阅读</span>
        <div class="article-nav__divider" />
        <button type="button" class="article-nav__share" id="article-share-button">分享</button>
        <button
          type="button"
          class="article-nav__theme"
          id="article-theme-toggle"
          aria-label="切换主题"
        >
          ◑
        </button>
      </div>
    </div>
  </nav>

  <main class="container article-main">
    <header class="article-header article-fade article-fade--0">
      <div class="meta-row">
        <span class="category-badge" style={`background:${"var(--accent-soft)"};color:${"var(--accent)"};`}>
          {post.data.category}
        </span>
        {post.data.tags.slice(1).map((tag) => (
          <a href={tagHref(tag)} class="article-tag article-tag--ghost">#{tag}</a>
        ))}
      </div>
      <h1 class="article-title">{post.data.title}</h1>
      {post.data.subtitle && <p class="article-subtitle">{post.data.subtitle}</p>}
      <div class="article-meta-strip">
        <div class="author article-meta-strip__author">
          {authorHasImageAvatar ? (
            <img class="avatar avatar--image" src={authorAvatar} alt={`${post.data.author.name} 的头像`} loading="lazy" decoding="async" />
          ) : (
            <div class="avatar">{authorAvatar}</div>
          )}
          <div>
            <div>{post.data.author.name}</div>
            <div class="meta-note">{post.data.author.bio}</div>
          </div>
        </div>
        <div class="article-meta-strip__stats">
          <div class="article-meta-stat">
            <div class="article-meta-stat__label">发布</div>
            <div class="article-meta-stat__value">{formatDisplayDate(post.data.publishedAt)}</div>
          </div>
          {post.data.updatedAt && (
            <div class="article-meta-stat">
              <div class="article-meta-stat__label">更新</div>
              <div class="article-meta-stat__value">{formatDisplayDate(post.data.updatedAt)}</div>
            </div>
          )}
          <div class="article-meta-stat">
            <div class="article-meta-stat__label">阅读</div>
            <div class="article-meta-stat__value">{post.data.readTime}</div>
          </div>
        </div>
      </div>
      {post.data.cover && (
        <div
          class="article-cover"
          style={post.data.coverPosition ? `--cover-position:${post.data.coverPosition};` : undefined}
        >
          <img src={post.data.cover} alt={post.data.title} />
        </div>
      )}
      {!post.data.cover && <div class="article-cover article-cover--placeholder">cover image — 1200 × 630</div>}
    </header>

    <div class="article-shell">
      <article class="article-body article-fade article-fade--1">
        <div class="article-prose">
          <slot />
        </div>
        <footer class="article-footer">
          <div class="tag-row">
            {post.data.tags.map((tag) => (
              <a href={tagHref(tag)} class="article-tag">#{tag}</a>
            ))}
          </div>
          <div class="article-author-card">
            {authorHasImageAvatar ? (
              <img class="avatar avatar--image article-author-card__avatar" src={authorAvatar} alt={`${post.data.author.name} 的头像`} loading="lazy" decoding="async" />
            ) : (
              <div class="avatar article-author-card__avatar">{authorAvatar}</div>
            )}
            <div>
              <div class="article-author-card__title">作者 · {post.data.author.name}</div>
              <div class="meta-note">
                {post.data.author.bio} 感谢阅读到这里，如果这篇文章对你有帮助，欢迎分享给需要的朋友。
              </div>
              <div class="tag-row article-author-card__links">
                {authorLinks.map((link) => (
                  <a
                    href={link.href}
                    class="article-author-card__link"
                    target={link.external ? "_blank" : undefined}
                    rel={link.external ? "noreferrer" : undefined}
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </footer>
      </article>

      <aside class="article-aside article-fade article-fade--2">
        <div class="toc-card">
          <div class="eyebrow">目录</div>
          <ul>
            {headings
              .filter((heading) => heading.depth === 2 || heading.depth === 3)
              .map((heading) => (
                <li>
                  <a href={`#${heading.slug}`} data-toc-link={heading.slug} data-depth={heading.depth}>
                    {heading.text}
                  </a>
                </li>
              ))}
          </ul>
        </div>
      </aside>
    </div>

    <div class="article-related">
      <div class="eyebrow">相关文章</div>
      <div class="article-related__grid">
        {relatedPosts.map((item) => (
          <a href={`/blog/${item.id}/`} class="article-related__card">
            <div class="article-related__cat">{item.data.category}</div>
            <div class="article-related__title">{item.data.title}</div>
            <div class="article-related__meta">
              {formatDisplayDate(item.data.publishedAt)} · {item.data.readTime}
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="article-backtop">
      <button type="button" class="article-backtop__button" onclick="window.scrollTo({top:0,behavior:'smooth'})">
        ↑ 回到顶部
      </button>
    </div>
  </main>

  <script is:inline define:vars={{ headings }}>
    (() => {
      const progress = document.createElement("div");
      progress.className = "progress-bar";
      document.body.appendChild(progress);

      const links = headings.map((heading) =>
        document.querySelector(`[data-toc-link="${heading.slug}"]`)
      );

      const onScroll = () => {
        const el = document.documentElement;
        const max = el.scrollHeight - el.clientHeight;
        const pct = max > 0 ? (el.scrollTop / max) * 100 : 0;
        progress.style.width = `${pct}%`;

        let active = "";
        for (const heading of headings) {
          const target = document.getElementById(heading.slug);
          if (target && target.getBoundingClientRect().top < 120) active = heading.slug;
        }

        links.forEach((link) => {
          if (!link) return;
          link.classList.toggle("active", link.dataset.tocLink === active);
        });
      };

      const toggle = document.getElementById("article-theme-toggle");
      const shareButton = document.getElementById("article-share-button");
      const backLink = document.querySelector(".article-nav__back");
      const normalizePath = (path) => (path.endsWith("/") ? path : `${path}/`);
      const currentPath = normalizePath(window.location.pathname);
      const applyBackHref = (target) => {
        if (!backLink || !target || normalizePath(target) === currentPath) return;
        backLink.setAttribute("href", target);
      };

      const queryFrom = new URLSearchParams(window.location.search).get("from");
      if (queryFrom === "home") {
        applyBackHref("/");
      }

      try {
        if (document.referrer) {
          const referrerUrl = new URL(document.referrer);
          if (referrerUrl.origin === window.location.origin) {
            const refPath = normalizePath(referrerUrl.pathname);
            if (refPath === "/" || refPath === "/blog/" || refPath.startsWith("/blog/tags/")) {
              const refTarget = `${refPath}${referrerUrl.search}${referrerUrl.hash}`;
              applyBackHref(refTarget);
            }
          }
        }
      } catch {
        // Keep the default /blog/ fallback when the referrer cannot be parsed.
      }

      const syncThemeButton = () => {
        if (!toggle) return;
        toggle.textContent = document.documentElement.dataset.theme === "dark" ? "☀" : "◑";
      };

      toggle?.addEventListener("click", () => {
        const nextDark = document.documentElement.dataset.theme !== "dark";
        if (nextDark) {
          document.documentElement.dataset.theme = "dark";
          localStorage.setItem("kai-theme", "dark");
        } else {
          delete document.documentElement.dataset.theme;
          localStorage.setItem("kai-theme", "light");
        }
        syncThemeButton();
      });

      shareButton?.addEventListener("click", async () => {
        const url = window.location.href;
        try {
          await navigator.clipboard.writeText(url);
          shareButton.textContent = "已复制";
          window.setTimeout(() => {
            shareButton.textContent = "分享";
          }, 1400);
        } catch {
          window.open(url, "_blank", "noopener,noreferrer");
        }
      });

      syncThemeButton();
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("beforeunload", () => {
        progress.remove();
      });
    })();
  </script>
</BaseLayout>
