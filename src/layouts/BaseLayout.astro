---
import "../styles/global.css";
import ThemeToggle from "../components/react/ThemeToggle";
import { navItems, siteCompliance, siteMeta } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  hideHeader?: boolean;
  hideFooter?: boolean;
}

const {
  title = siteMeta.title,
  description = siteMeta.description,
  currentPath = Astro.url.pathname,
  hideHeader = false,
  hideFooter = false
} = Astro.props;

const isAuthed = Astro.locals?.auth?.isAuthed ?? false;
const loginNext = currentPath && currentPath !== "/login" ? currentPath : "/";
const normalizePath = (path: string) => (path !== "/" && path.endsWith("/") ? path.slice(0, -1) : path);
const normalizedCurrentPath = normalizePath(currentPath);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=DM+Serif+Display:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script is:inline src="/scripts/theme-init.js"></script>
  </head>
  <body>
    {!hideHeader && (
      <header class="site-header">
        <div class="container site-header__inner">
          <a class="brand" href="/">
            <img class="brand__mark" src="/favicon.svg" alt="" width="34" height="34" decoding="async" />
            <span class="brand__name">{siteMeta.title}</span>
          </a>
          <div class="header-actions">
            <nav class="nav" aria-label="主导航">
              {navItems.map((item) => (
                <a href={item.href} aria-current={normalizedCurrentPath === normalizePath(item.href) ? "page" : undefined}>
                  {item.label}
                </a>
              ))}
            </nav>
            <div class="nav-divider" />
            {isAuthed ? (
              <form method="POST" action="/api/auth/logout" class="auth-link-form">
                <button type="submit" class="auth-link" title="退出登录">退出</button>
              </form>
            ) : (
              <a class="auth-link" href={`/login?next=${encodeURIComponent(loginNext)}`}>登录</a>
            )}
            <ThemeToggle client:load />
          </div>
        </div>
      </header>
    )}

    <div class="shell">
      <slot />
    </div>

    {!hideFooter && (
      <footer class="footer">
        <div class="container footer__inner">
          <div>{siteMeta.title}</div>
          <div>{siteMeta.description}</div>
        </div>
        <div class="container footer__compliance">
          <a href={siteCompliance.icpUrl}>{siteCompliance.icpRecord}</a>
          <span aria-hidden="true">·</span>
          <a href="/privacy/">隐私说明</a>
        </div>
      </footer>
    )}
  </body>
</html>
