---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteMeta } from "../data/site";

export const prerender = false;

const url = Astro.url;
const error = url.searchParams.get("error");
const next = url.searchParams.get("next") || "/";

if (Astro.locals.auth.isAuthed) {
  return Astro.redirect(next);
}

const errorMessage =
  error === "bad-password"
    ? "密码错误，请再试一次。"
    : error === "missing-config"
      ? "登录功能尚未配置：请设置 SITE_AUTH_PASSWORD 与 SITE_AUTH_SECRET 环境变量。"
      : null;
---

<BaseLayout title={`登录 — ${siteMeta.title}`} currentPath="/login" hideHeader={false} hideFooter={true}>
  <main class="login-wrapper">
    <div class="login-card">
      <div class="login-header">
        <div class="login-brand">
          <img class="brand__mark" src="/favicon.svg" alt="" width="48" height="48" decoding="async" />
        </div>
        <div class="eyebrow">Sign in</div>
        <h1 class="login-title">欢迎回来</h1>
        <p class="login-desc">
          未登录可浏览大多数页面。登录后将解锁完整 IP、订阅明细、服务器详情以及 AI 工具限额等敏感数据。
        </p>
      </div>

      {errorMessage && (
        <div class="login-error">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
          </svg>
          <span>{errorMessage}</span>
        </div>
      )}

      <form method="POST" action="/api/auth/login" class="login-form" data-login-form>
        <input type="hidden" name="next" value={next} />
        
        <div class="login-field">
          <label for="password">验证密码</label>
          <div class="input-wrapper">
            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
            <input id="password" type="password" name="password" required autocomplete="current-password" autofocus placeholder="输入密码以继续..." />
          </div>
        </div>

        <button type="submit" class="login-button">
          <span>登录</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </form>
      <div class="login-error" data-login-error hidden aria-live="polite"></div>
    </div>
  </main>
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-login-form]");
  const errorBox = document.querySelector<HTMLElement>("[data-login-error]");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const formData = new FormData(form);
    const password = String(formData.get("password") || "");
    const next = String(formData.get("next") || "/");

    errorBox?.setAttribute("hidden", "");
    try {
      const response = await fetch(form.action, {
        method: "POST",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        body: JSON.stringify({ password, next }),
      });
      const payload = (await response.json().catch(() => ({}))) as { error?: string; next?: string };
      if (!response.ok) {
        const message = payload.error === "bad-password" ? "密码错误，请再试一次。" : "登录暂时不可用，请稍后重试。";
        if (errorBox) {
          errorBox.textContent = message;
          errorBox.removeAttribute("hidden");
        }
        form.querySelector<HTMLInputElement>("#password")?.focus();
        return;
      }
      window.location.assign(payload.next || "/");
    } catch {
      if (errorBox) {
        errorBox.textContent = "网络连接失败，请稍后重试。";
        errorBox.removeAttribute("hidden");
      }
    }
  });
</script>

<style>
  .login-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 80vh;
    padding: 40px 20px;
    position: relative;
    z-index: 1;
  }

  .login-wrapper::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--accent-soft) 0%, transparent 70%);
    opacity: 0.5;
    z-index: -1;
    pointer-events: none;
  }

  .login-card {
    width: 100%;
    max-width: 440px;
    padding: 48px 40px;
    border-radius: 24px;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    box-shadow: var(--shadow-lg);
    position: relative;
    overflow: hidden;
  }

  .login-card::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--accent), oklch(0.52 0.16 70));
  }

  .login-header {
    text-align: center;
    margin-bottom: 36px;
  }

  .login-brand {
    display: flex;
    justify-content: center;
    margin-bottom: 24px;
  }

  .brand__mark {
    width: 48px;
    height: 48px;
    display: block;
    object-fit: contain;
  }

  .eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 700;
    margin-bottom: 8px;
  }

  .login-title {
    font-family: "DM Serif Display", serif;
    font-size: 2rem;
    color: var(--text);
    margin: 0 0 12px 0;
    letter-spacing: -0.02em;
  }

  .login-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .login-error {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-radius: 12px;
    background: var(--red-soft);
    border: 1px solid color-mix(in oklch, var(--red) 30%, transparent);
    color: var(--red);
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 24px;
    animation: fadeIn 0.3s ease;
  }

  .login-error svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .login-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .login-field label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
  }

  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input-icon {
    position: absolute;
    left: 14px;
    width: 18px;
    height: 18px;
    color: var(--text-faint);
    pointer-events: none;
    transition: color 0.2s;
    z-index: 2;
  }

  .login-field input {
    width: 100%;
    font: inherit;
    font-size: 0.95rem;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 14px 14px 42px;
    outline: none;
    transition: all 0.2s ease;
    box-shadow: var(--shadow-sm);
  }

  .login-field input::placeholder {
    color: var(--text-faint);
  }

  .login-field input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-soft);
    background: var(--bg-card);
  }

  .login-field input:focus ~ .input-icon,
  .login-field input:not(:placeholder-shown) ~ .input-icon {
    color: var(--accent);
  }

  .login-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    appearance: none;
    border: none;
    cursor: pointer;
    background: var(--accent);
    color: white;
    font: inherit;
    font-size: 0.95rem;
    font-weight: 600;
    padding: 14px 20px;
    border-radius: 12px;
    transition: all 0.2s ease;
    box-shadow: 0 4px 12px var(--accent-soft);
  }

  .login-button svg {
    width: 18px;
    height: 18px;
    transition: transform 0.2s;
  }

  .login-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px var(--accent-soft);
    filter: brightness(1.05);
  }

  .login-button:hover svg {
    transform: translateX(4px);
  }

  .login-button:active {
    transform: translateY(0);
    box-shadow: 0 2px 8px var(--accent-soft);
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 480px) {
    .login-card {
      padding: 36px 24px;
      border-radius: 20px;
    }
  }
</style>
