---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteMeta } from "../data/site";

const avatarSrc = "/uploads/aleksi-avatar.jpg";

const researchItems = [
  {
    label: "Writing System",
    text: "用 Astro、MDX 和内容集合整理文章，让写作、归档和后续维护尽量简单。"
  },
  {
    label: "Personal Workspace",
    text: "保留原项目的工作台能力，逐步把订阅、项目、看板和常用工具收进一个页面。"
  },
  {
    label: "AI Tooling",
    text: "记录 AI 工具、自动化流程和开发经验，把折腾过程沉淀成可复用的笔记。"
  },
  {
    label: "Self-hosting",
    text: "学习更安全、稳定的自托管方式，让公开页面和私有后端保持清晰边界。"
  }
];

const stackGroups = [
  {
    code: "01",
    title: "Web & Content",
    caption: "博客、内容和页面构建",
    items: [
      { name: "Astro", url: "https://astro.build/" },
      { name: "React", url: "https://react.dev/" },
      { name: "TypeScript", url: "https://www.typescriptlang.org/" },
      { name: "MDX", url: "https://mdxjs.com/" },
      { name: "D3", url: "https://d3js.org/" }
    ]
  },
  {
    code: "02",
    title: "AI & Tools",
    caption: "辅助写作、编码和效率工具",
    items: [
      { name: "Claude Code", url: "https://www.anthropic.com/claude-code" },
      { name: "Codex CLI", url: "https://github.com/openai/codex" },
      { name: "Gemini CLI", url: "https://github.com/google-gemini/gemini-cli" },
      { name: "Cursor", url: "https://www.cursor.com/" },
      { name: "Anthropic SDK", url: "https://docs.anthropic.com/" },
      { name: "OpenAI SDK", url: "https://platform.openai.com/docs/libraries" }
    ]
  },
  {
    code: "03",
    title: "Dashboard",
    caption: "图表、看板和个人数据界面",
    items: [
      { name: "Recharts", url: "https://recharts.org/" },
      { name: "TopoJSON", url: "https://github.com/topojson/topojson-client" },
      { name: "CSS", url: "https://developer.mozilla.org/docs/Web/CSS" },
      { name: "Content Collections", url: "https://docs.astro.build/en/guides/content-collections/" }
    ]
  },
  {
    code: "04",
    title: "Infra & Networking",
    caption: "部署、自托管和网络工具",
    items: [
      { name: "Linux", url: "https://www.kernel.org/" },
      { name: "Docker", url: "https://www.docker.com/" },
      { name: "Cloudflare Tunnel", url: "https://developers.cloudflare.com/cloudflare-one/connections/connect-networks/" },
      { name: "Caddy", url: "https://caddyserver.com/" },
      { name: "WireGuard", url: "https://www.wireguard.com/" },
      { name: "Tailscale", url: "https://tailscale.com/" },
      { name: "Mihomo", url: "https://wiki.metacubex.one/" }
    ]
  }
];
---

<BaseLayout
  title={`关于 — ${siteMeta.title}`}
  description={siteMeta.description}
  currentPath="/about"
>
  <main class="container about-page">
    <section class="about-hero" aria-labelledby="about-title">
      <div class="about-field" aria-hidden="true"></div>
      <div class="about-hero__copy">
        <div class="eyebrow">About</div>
        <h1 id="about-title" class="about-hero__title">
          <span class="about-hero__title-accent">Aleksi</span> Zheng
        </h1>
        <p class="about-hero__lead">
          这里会慢慢变成我的个人博客、工作台、看板和知识库。
          我会在这里记录学习过程、工具折腾、项目实践，以及那些值得反复回看的想法。
        </p>
        <div class="about-hero__actions">
          <a href={`mailto:${siteMeta.email}`} class="about-link about-link--primary">{siteMeta.email}</a>
          <a href={siteMeta.github} class="about-link" target="_blank" rel="noreferrer">GitHub · AJ1E</a>
        </div>
      </div>

      <aside class="about-identity" aria-label="身份摘要">
        <div class="about-identity__head">
          <div class="about-identity__mark about-identity__mark--image">
            <img src={avatarSrc} alt={`${siteMeta.author} 的头像`} loading="lazy" decoding="async" />
          </div>
          <div class="about-identity__meta">
            <span class="about-identity__role">
              <span>Master of Engineering</span>
              <span>Computer Technology</span>
            </span>
            <span class="about-identity__org">SICAU→SWU</span>
          </div>
        </div>
        <dl class="about-identity__list">
          <div>
            <dt>Focus</dt>
            <dd>Embedded AI · Robotics · Edge Computing</dd>
          </div>
          <div>
            <dt>Interests</dt>
            <dd>AI Research · Networking · Self-host</dd>
          </div>
          <div>
            <dt>Traits</dt>
            <dd>Lifelong learner · Stay hungry · Stay foolish</dd>
          </div>
        </dl>
      </aside>
    </section>

    <section class="about-section" aria-labelledby="about-research">
      <header class="about-section__head">
        <div class="eyebrow">Research & Practice</div>
        <h2 id="about-research" class="about-section__title">写作、工具和个人工作台</h2>
      </header>
      <div class="about-research-grid">
        {researchItems.map((item) => (
          <article class="about-research-card about-reveal">
            <span>{item.label}</span>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="about-section" aria-labelledby="about-stack">
      <header class="about-section__head">
        <div class="eyebrow">Tech Stack</div>
        <h2 id="about-stack" class="about-section__title">当前使用的技术与工具</h2>
        <p class="about-section__copy">
          先沿用原项目成熟的技术组合，后续只在确实需要时再小步替换或扩展。
        </p>
      </header>
      <div class="about-stack">
        {stackGroups.map((group) => (
          <article class="about-stack__group about-reveal">
            <header class="about-stack__head">
              <span class="about-stack__code">{group.code}</span>
              <div>
                <h3 class="about-stack__title">{group.title}</h3>
                <p class="about-stack__caption">{group.caption}</p>
              </div>
            </header>
            <ul class="about-stack__list">
              {group.items.map((item) => (
                <li>
                  <a href={item.url} target="_blank" rel="noreferrer">{item.name}</a>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const page = document.querySelector(".about-page");
      if (!page) return;

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const revealItems = [...page.querySelectorAll(".about-reveal")];

      if (reduceMotion) {
        revealItems.forEach((item) => item.classList.add("is-visible"));
        return;
      }

      revealItems.forEach((item, index) => {
        item.style.setProperty("--about-delay", `${Math.min(index * 70, 420)}ms`);
      });

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.18 }
      );
      revealItems.forEach((item) => observer.observe(item));
    })();
  </script>
</BaseLayout>
