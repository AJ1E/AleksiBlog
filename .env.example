# Shared-password login.
# Generate SITE_AUTH_SECRET with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SITE_AUTH_PASSWORD=change-me
SITE_AUTH_SECRET=replace-with-at-least-16-random-characters

# Development only: bypass the login gate.
# SITE_AUTH_DISABLE=1

# Astro BFF upstreams. Defaults are loopback.
AI_USAGE_BACKEND_URL=http://127.0.0.1:8787
IP_RISK_BACKEND_URL=http://127.0.0.1:8788
SERVER_STATUS_BACKEND_URL=http://127.0.0.1:8789
# Production only: loopback helper behind Astro's authenticated notes sync API.
# NOTES_SYNC_BACKEND_URL=http://127.0.0.1:8790

# Production only: enable after Nginx is the only public entry point and it
# overwrites X-Real-IP with the direct visitor address. Leave unset locally.
# TRUST_PROXY_HEADERS=1

# Optional helper budgets.
# CODEX_MONTHLY_BUDGET_USD=50
# GEMINI_MONTHLY_BUDGET_USD=50
# CLAUDE_5H_PROMPT_BUDGET=200
# CLAUDE_7D_PROMPT_BUDGET=2000

# Optional cost-estimate inputs. Use official GLM-5.2 prices only; never put
# an API key here. Example shape: {"input":1,"cachedInput":0.1,"output":5}
# AI_USAGE_GLM52_PRICING_JSON={"input":0,"cachedInput":0,"output":0}
# Optional daily USD/CNY fallback when the exchange-rate provider is unavailable.
# AI_USAGE_USD_CNY_RATE=7.2

# Optional CLI home overrides.
# CLAUDE_CONFIG_DIR=/home/you/.claude
# CODEX_HOME=/home/you/.codex
# GEMINI_HOME=/home/you/.gemini

# Optional Beszel database path for the server status helper.
# BESZEL_DB_PATH=/opt/beszel/beszel_data/data.db

# Optional public Obsidian notes repository. Defaults to AJ1E/ObsdianNotes.
# NOTES_GITHUB_REPO=AJ1E/ObsdianNotes
# NOTES_GITHUB_BRANCH=main
